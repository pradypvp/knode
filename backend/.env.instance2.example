# Copy to a second env file and load when running a parallel backend, e.g.:
#   export $(grep -v '^#' .env.instance2 | xargs) && npm run dev
# Or merge these into .env when testing instance 2 only.

NODE_ENV=development
PORT=4001
# Both Next dev servers (3000 default + 3001 second UI) may call this API
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
DATABASE_URL=postgresql://knode:knode@localhost:5433/knode
REDIS_URL=redis://localhost:16380
# Use the SAME JWT_SECRET as instance 1 only if you intentionally share tokens (usually don’t).
JWT_SECRET=9f3c8e2b7a4d6f1c5e8a2b9d4f7c1e3a6b8d0f2c9a1e4b7d6c3f8a5e2b1d9c7
JWT_EXPIRES_IN=7d
AI_ENGINE_URL=http://localhost:8010
